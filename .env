# AI Configuration - Multi-provider support with automatic fallback
# Configure at least ONE key - the system will automatically fall back if one fails
# Priority order: Groq → Anthropic → OpenAI → Azure → Google → DeepSeek

# Groq API (FAST - recommended for speed)
# Get free key from: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (excellent quality)
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT-4o
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Azure OpenAI
# Get key from: https://portal.azure.com
AZURE_API_KEY=

# Google Gemini
# Get key from: https://ai.google.dev
GOOGLE_API_KEY=

# DeepSeek (fallback)
# Get key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Model Configuration
AI_MODEL=groq/mixtral-8x7b-32768
AI_TIMEOUT=60
AI_MAX_RETRIES=3

# Server Configuration
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# Security
API_KEY_REQUIRED=false
ADMIN_API_KEY=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_MAX_PAGES=5
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# Phishlet Configuration
GENERATE_FORCE_POST=true
GENERATE_JS_INJECT=true
EVILGINX_MIN_VER=3.2.0

# Logging
LOG_LEVEL=INFO
AUDIT_LOGGING_ENABLED=true
LOG_SENSITIVE_DATA=false
